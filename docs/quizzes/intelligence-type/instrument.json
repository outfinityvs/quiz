{
  "id": "intelligence-type",
  "version": 1,
  "title": "Intelligence Type Profile",
  "language": "en",
  "introduction": {
    "subtitle": "What type of intelligence do you have? A non-classical, multi-axis map of cognitive strengths — not an IQ test.",
    "description": "<p>This does not measure general intelligence or produce an IQ score. It maps where your cognitive strengths sit across eight dimensions, so you understand the shape of your thinking rather than its rank.</p><p>For each task, rate how easily you could do it. There is no advantage to overestimating — the result is most useful when it is honest.</p>",
    "duration": "20 self-rating tasks. Approximately five minutes.",
    "privacyNote": "Your answers stay in this browser. The result belongs to you. Sharing is your choice.",
    "disclaimer": "Inspired by Howard Gardner’s Multiple Intelligences theory. This is not an IQ test and does not measure general intelligence or produce an IQ score. Items are original.",
    "startButton": "Map my intelligence"
  },
