      "options": [
        { "key": "A", "text": "Roughly halved, from 93 to about 37", "correct": true, "bias": "realistic", "dimensionScores": { "health": 1 } },
        { "key": "B", "text": "Stayed about the same", "correct": false, "bias": "static", "dimensionScores": { "health": 0 } },
        { "key": "C", "text": "Increased, especially in low-income regions", "correct": false, "bias": "pessimistic", "dimensionScores": { "health": 0 } }
      ]
    },
    {
