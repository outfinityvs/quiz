{
  "id": "world-perception",
  "version": 1,
  "title": "World Perception Challenge",
  "language": "en",
  "introduction": {
    "subtitle": "How realistic is your view of the world? 12 questions, real open data, no moralizing.",
    "description": "<p>This is not a trivia contest. It tests your intuition about global trends in health, economics, demographics, and climate — against open data from the World Bank, Our World in Data, and the WHO. Your wrong answers are informative: they reveal where your worldview is pessimistic, optimistic, or selectively distorted.</p><p>Each question has one answer closest to the data and two plausible distractors. Pick the one you believe is closest.</p>",
    "duration": "12 questions. Approximately three minutes.",
    "privacyNote": "Your answers stay in this browser. The result belongs to you. Sharing is your choice.",
    "disclaimer": "Estimates reflect latest available statistics as of 2023-2024. Figures are approximate; sources are cited per question. This is an intuition test, not a knowledge exam.",
    "startButton": "Test my perception"
  },
  "questions": [
    {
      "id": "h1", "text": "What percentage of the world's one-year-old children are vaccinated against measles?", "type": "profile", "dimension": "health",
      "source": "WHO/UNICEF estimates, 2023",
      "sourceUrl": "https://www.who.int/news-room/fact-sheets/detail/measles",
      "options": [
        { "key": "A", "text": "About 45%", "correct": false, "bias": "pessimistic", "dimensionScores": { "health": 0 } },
        { "key": "B", "text": "About 84%", "correct": true, "bias": "realistic", "dimensionScores": { "health": 1 } },
        { "key": "C", "text": "About 98%", "correct": false, "bias": "optimistic", "dimensionScores": { "health": 0 } }
      ]
    },
    {
      "id": "h2", "text": "How has the global under-five mortality rate (per 1,000 live births) changed since 1990?", "type": "profile", "dimension": "health",
      "source": "UN IGME / Our World in Data",
